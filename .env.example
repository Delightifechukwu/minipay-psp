# MiniPay PSP — Environment Variables
# Copy this to .env and fill in production values
# NEVER commit .env to version control

# Database
DB_URL=jdbc:postgresql://localhost:5432/minipay
DB_USER=minipay
DB_PASS=secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — MUST be changed in production (min 256-bit key)
JWT_SECRET=minipay-super-secret-key-change-in-production-must-be-256-bits-long
JWT_TTL_MIN=30
JWT_REFRESH_TTL_H=24

# Spring
SPRING_PROFILES_ACTIVE=dev
