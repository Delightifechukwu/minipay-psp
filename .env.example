# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/minipay
DB_USER=minipay
DB_PASS=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 256 bits (32+ chars). Generate: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_256BIT_KEY
JWT_TTL_MIN=30
JWT_REFRESH_TTL_H=24

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for browser clients
CORS_ALLOWED_ORIGINS=https://app.example.com

# ── Observability ─────────────────────────────────────────────────────────────
TRACING_PROBABILITY=0.1
ZIPKIN_URL=http://localhost:9411/api/v2/spans

# ── Spring profile ────────────────────────────────────────────────────────────
# Use "prod" in production for JSON structured logging
SPRING_PROFILES_ACTIVE=prod
